# ================================================================
#  Dream Ludo — Server Configuration
#  INSTRUCTIONS:
#    1. Copy this file:  cp example.env .env
#    2. Fill in every value below
#    3. Run setup:       sudo bash setup-ubuntu.sh
# ================================================================

# ----------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_SOCKET=/var/run/mysqld/mysqld.sock
DB_NAME=dreamludo
DB_USER=dreamludo
DB_PASS=ChangeMe_StrongPassword123!

# ----------------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------------
APP_NAME="Dream Ludo"
# Your domain — no trailing slash, no https://
DOMAIN=dream.netlifegy.com
APP_URL=https://dream.netlifegy.com
# Absolute path where project files will live on the server
APP_ROOT=/var/www/dreamludo
TIMEZONE=Asia/Kolkata
# Must match the value baked into the APK  (default: 1234567890)
PURCHASE_KEY=1234567890
PHP_VERSION=8.2

# ----------------------------------------------------------------
# ADMIN  — change immediately after first login
# ----------------------------------------------------------------
ADMIN_USERNAME=admin
# This is the SHA1 of your desired password. Default = admin123
# Generate a new one: echo -n "YourPassword" | sha1sum
ADMIN_PASSWORD_SHA1=6367c48dd193d56ea7b0baad25b19455e529f5ee

# ----------------------------------------------------------------
# SSL  (Let's Encrypt — free, auto-renews)
# ----------------------------------------------------------------
ENABLE_SSL=1
CERTBOT_EMAIL=you@example.com

# ----------------------------------------------------------------
# FIREBASE / FCM  (push notifications)
# Get these from Firebase Console → Project Settings
# ----------------------------------------------------------------
FCM_SERVER_KEY=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# ----------------------------------------------------------------
# PAYMENT GATEWAYS
# ----------------------------------------------------------------
# PayTM
PAYTM_MERCHANT_ID=
PAYTM_MERCHANT_KEY=

# PayU
PAYU_ID=
PAYU_KEY=
PAYU_SALT=

# ----------------------------------------------------------------
# EMAIL / SMTP  (for password resets etc.)
# ----------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME="Dream Ludo"

# ----------------------------------------------------------------
# SOLANA / CRYPTO WALLET
# ----------------------------------------------------------------
# Primary Solana RPC endpoint
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Backup RPC (used if primary is down)
SOLANA_RPC_BACKUP=https://solana-api.projectserum.com
# mainnet | devnet | testnet
SOLANA_NETWORK=mainnet
# Platform hot-wallet public address (receives entry fees, pays out prizes)
SOLANA_ADMIN_WALLET=
# Base58-encoded private key of the hot wallet (for automated payouts)
# Store this securely — never commit to git
SOLANA_ADMIN_PRIVATE_KEY=
